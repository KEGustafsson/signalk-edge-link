{
  "name": "signalk-edge-link",
  "version": "2.1.0-beta.8",
  "description": "SignalK Edge Link. Secure UDP link for data exchange.",
  "main": "lib/index.js",
  "files": [
    "lib/",
    "public/",
    "schemas/"
  ],
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-network",
    "signalk-webapp",
    "signalk-category-utility",
    "signalk-plugin-configurator"
  ],
  "signalk": {
    "appIcon": "./icons/icon-72x72.png",
    "displayName": "Edge Link Configuration"
  },
  "signalk-plugin-enabled-by-default": false,
  "scripts": {
    "clean:lib": "node -e \"const fs=require('fs');if(fs.existsSync('lib'))fs.rmSync('lib',{recursive:true,force:true});\"",
    "clean:public": "node -e \"const fs=require('fs');if(fs.existsSync('public'))fs.rmSync('public',{recursive:true,force:true});\"",
    "build": "npm run build:ts && npm run build:web",
    "build:web": "npm run clean:public && webpack --mode production",
    "build:ts": "npm run clean:lib && tsc",
    "check:ts": "tsc --noEmit",
    "dev": "webpack --mode development --watch",
    "test": "jest --runInBand",
    "test:v2": "jest __tests__/v2/",
    "test:integration": "jest test/integration/",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,json,md}\"",
    "migrate:config": "node lib/scripts/migrate-config.js",
    "cli": "node lib/bin/edge-link-cli.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.0.0",
    "@rjsf/core": "^5.18.4",
    "@rjsf/utils": "^5.18.4",
    "@rjsf/validator-ajv8": "^5.18.4",
    "@signalk/server-admin-ui-dependencies": "1.0.1",
    "ping-monitor": "^0.8.2"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@babel/preset-react": "^7.22.0",
    "@types/node": "^25.3.5",
    "babel-loader": "^9.1.2",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^6.8.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "html-webpack-plugin": "^5.5.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.4.3",
    "mini-css-extract-plugin": "^2.7.6",
    "prettier": "^3.6.2",
    "style-loader": "^3.3.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "webpack": "^5.102.1",
    "webpack-cli": "^5.1.4"
  },
  "engines": {
    "node": ">=16"
  },
  "author": "Karl-Erik Gustafsson",
  "repository": "https://github.com/KEGustafsson/signalk-edge-link",
  "license": "MIT",
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "lib/**/*.js",
      "!lib/webapp/**",
      "!lib/components/**",
      "!lib/utils/**"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js",
      "**/*.spec.js"
    ],
    "transform": {
      "^.+\\.js$": [
        "babel-jest",
        {
          "presets": [
            [
              "@babel/preset-env",
              {
                "targets": {
                  "node": "current"
                }
              }
            ]
          ]
        }
      ],
      "^.+\\.ts$": "ts-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "js",
      "json",
      "node"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/public/"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  },
  "bin": {
    "edge-link-cli": "lib/bin/edge-link-cli.js"
  },
  "lint-staged": {
    "*.js": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.ts": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
