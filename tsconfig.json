{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "types": ["node"],
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError": true,
    "allowJs": false
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "node_modules",
    "public",
    "lib",
    "__tests__",
    "test",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/webapp"
  ]
}
