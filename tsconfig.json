{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "jsx": "react-jsx",
    "outDir": "dist",
    "rootDir": "."
  },
  "include": [
    "index.ts",
    "bin/**/*.ts",
    "lib/**/*.ts",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "test/**/*.ts",
    "__tests__/**/*.ts"
  ],
  "exclude": ["node_modules", "public", "dist"]
}
