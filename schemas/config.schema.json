{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://signalk-edge-link/schemas/config.schema.json",
  "title": "Signal K Edge Link Plugin Configuration",
  "description": "Unified configuration schema supporting both legacy single-connection and modern multi-connection layouts.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "connections": {
      "type": "array",
      "title": "Connections",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/connection"
      }
    },
    "name": {
      "type": "string",
      "maxLength": 40
    },
    "serverType": {
      "type": "string",
      "enum": [
        "server",
        "client"
      ]
    },
    "udpPort": {
      "type": "number",
      "minimum": 1024,
      "maximum": 65535
    },
    "secretKey": {
      "type": "string",
      "minLength": 32,
      "maxLength": 32
    },
    "protocolVersion": {
      "type": "number",
      "enum": [
        1,
        2
      ],
      "default": 1
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "connections"
        ]
      },
      "then": {
        "properties": {
          "connections": {
            "minItems": 1,
            "type": "array"
          }
        }
      }
    }
  ],
  "definitions": {
    "threshold": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "warning": {
          "type": "number"
        },
        "critical": {
          "type": "number"
        }
      }
    },
    "bondingLink": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-[A-Za-z0-9_.-]+$": true
      },
      "properties": {
        "address": {
          "type": "string"
        },
        "port": {
          "type": "number",
          "minimum": 1024,
          "maximum": 65535
        },
        "interface": {
          "type": "string"
        }
      }
    },
    "connection": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-[A-Za-z0-9_.-]+$": true
      },
      "required": [
        "serverType",
        "udpPort",
        "secretKey"
      ],
      "properties": {
        "name": {
          "type": "string",
          "default": "connection",
          "maxLength": 40
        },
        "serverType": {
          "type": "string",
          "enum": [
            "server",
            "client"
          ],
          "default": "client"
        },
        "udpAddress": {
          "type": "string"
        },
        "udpPort": {
          "type": "number",
          "minimum": 1024,
          "maximum": 65535,
          "default": 4446
        },
        "secretKey": {
          "type": "string",
          "minLength": 32,
          "maxLength": 32
        },
        "useMsgpack": {
          "type": "boolean",
          "default": false
        },
        "usePathDictionary": {
          "type": "boolean",
          "default": false
        },
        "enableNotifications": {
          "type": "boolean",
          "default": false
        },
        "protocolVersion": {
          "type": "number",
          "enum": [
            1,
            2
          ],
          "default": 1
        },
        "helloMessageSender": {
          "type": "number",
          "minimum": 10,
          "maximum": 3600
        },
        "testAddress": {
          "type": "string"
        },
        "testPort": {
          "type": "number",
          "minimum": 1,
          "maximum": 65535
        },
        "pingIntervalTime": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 60
        },
        "alertThresholds": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^x-[A-Za-z0-9_.-]+$": true
          },
          "properties": {
            "rtt": {
              "$ref": "#/definitions/threshold"
            },
            "packetLoss": {
              "$ref": "#/definitions/threshold"
            },
            "retransmitRate": {
              "$ref": "#/definitions/threshold"
            },
            "jitter": {
              "$ref": "#/definitions/threshold"
            },
            "queueDepth": {
              "$ref": "#/definitions/threshold"
            }
          }
        },
        "reliability": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^x-[A-Za-z0-9_.-]+$": true
          },
          "properties": {
            "ackInterval": {
              "type": "number",
              "minimum": 20,
              "maximum": 5000
            },
            "ackResendInterval": {
              "type": "number",
              "minimum": 100,
              "maximum": 10000
            },
            "nakTimeout": {
              "type": "number",
              "minimum": 20,
              "maximum": 5000
            },
            "retransmitQueueSize": {
              "type": "number",
              "minimum": 100,
              "maximum": 50000
            },
            "maxRetransmits": {
              "type": "number",
              "minimum": 1,
              "maximum": 20
            },
            "retransmitMaxAge": {
              "type": "number",
              "minimum": 1000,
              "maximum": 300000
            },
            "retransmitMinAge": {
              "type": "number",
              "minimum": 200,
              "maximum": 30000
            },
            "retransmitRttMultiplier": {
              "type": "number",
              "minimum": 2,
              "maximum": 20
            },
            "ackIdleDrainAge": {
              "type": "number",
              "minimum": 500,
              "maximum": 30000
            },
            "forceDrainAfterMs": {
              "type": "number",
              "minimum": 2000,
              "maximum": 120000
            },
            "recoveryBurstSize": {
              "type": "number",
              "minimum": 10,
              "maximum": 1000
            },
            "recoveryBurstIntervalMs": {
              "type": "number",
              "minimum": 50,
              "maximum": 5000
            },
            "recoveryAckGapMs": {
              "type": "number",
              "minimum": 500,
              "maximum": 120000
            },
            "forceDrainAfterAckIdle": {
              "type": "boolean"
            },
            "recoveryBurstEnabled": {
              "type": "boolean"
            }
          }
        },
        "bonding": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^x-[A-Za-z0-9_.-]+$": true
          },
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "mode": {
              "type": "string",
              "enum": [
                "main-backup"
              ]
            },
            "primary": {
              "$ref": "#/definitions/bondingLink"
            },
            "backup": {
              "$ref": "#/definitions/bondingLink"
            },
            "failover": {
              "type": "object",
              "additionalProperties": false,
              "patternProperties": {
                "^x-[A-Za-z0-9_.-]+$": true
              },
              "properties": {
                "rttThreshold": {
                  "type": "number",
                  "minimum": 100,
                  "maximum": 5000
                },
                "lossThreshold": {
                  "type": "number",
                  "minimum": 0.01,
                  "maximum": 0.5
                },
                "healthCheckInterval": {
                  "type": "number",
                  "minimum": 500,
                  "maximum": 10000
                },
                "failbackDelay": {
                  "type": "number",
                  "minimum": 5000,
                  "maximum": 300000
                },
                "heartbeatTimeout": {
                  "type": "number",
                  "minimum": 1000,
                  "maximum": 30000
                }
              }
            }
          }
        },
        "congestionControl": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^x-[A-Za-z0-9_.-]+$": true
          },
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "targetRTT": {
              "type": "number",
              "minimum": 50,
              "maximum": 2000
            },
            "nominalDeltaTimer": {
              "type": "number",
              "minimum": 100,
              "maximum": 10000
            },
            "minDeltaTimer": {
              "type": "number",
              "minimum": 50,
              "maximum": 1000
            },
            "maxDeltaTimer": {
              "type": "number",
              "minimum": 1000,
              "maximum": 30000
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "serverType": {
                "const": "client"
              }
            },
            "required": [
              "serverType"
            ]
          },
          "then": {
            "required": [
              "udpAddress",
              "testAddress",
              "testPort"
            ]
          }
        }
      ]
    }
  }
}
