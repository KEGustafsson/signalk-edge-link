{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://signalk-edge-link/docs/configuration-schema.json",
  "title": "Signal K Edge Link documented configuration schema",
  "description": "Documentation-oriented schema for configuration payloads. Mirrors the runtime accepted by src/connection-config.ts (validateConnectionConfig) and the shared UI schema in src/shared/connection-schema.ts. Examples here are kept runtime-valid by the docs-parity test.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "connections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/connection"
      }
    },
    "managementApiToken": {
      "type": "string",
      "description": "Optional shared secret for management API requests. May also be supplied via SIGNALK_EDGE_LINK_MANAGEMENT_TOKEN."
    },
    "requireManagementApiToken": {
      "type": "boolean",
      "default": false,
      "description": "Require management API token auth even when no token is configured (fail closed)."
    }
  },
  "required": ["connections"],
  "examples": [
    {
      "connections": [
        {
          "name": "shore-server",
          "serverType": "server",
          "udpPort": 4446,
          "secretKey": "12345678901234567890123456789012",
          "protocolVersion": 3,
          "useMsgpack": true,
          "usePathDictionary": true
        },
        {
          "name": "boat-client",
          "serverType": "client",
          "udpAddress": "203.0.113.10",
          "udpPort": 4446,
          "secretKey": "12345678901234567890123456789012",
          "protocolVersion": 3,
          "useMsgpack": true,
          "usePathDictionary": true,
          "heartbeatInterval": 25000,
          "bonding": {
            "enabled": true,
            "mode": "main-backup",
            "primary": { "address": "203.0.113.10", "port": 4446 },
            "backup": { "address": "198.51.100.20", "port": 4446 },
            "failover": {
              "rttThreshold": 800,
              "lossThreshold": 0.1,
              "healthCheckInterval": 1000
            }
          },
          "congestionControl": {
            "enabled": true,
            "targetRTT": 300,
            "minDeltaTimer": 100,
            "maxDeltaTimer": 5000
          }
        }
      ]
    }
  ],
  "definitions": {
    "connection": {
      "type": "object",
      "additionalProperties": true,
      "required": ["serverType", "udpPort", "secretKey"],
      "properties": {
        "name": { "type": "string", "maxLength": 40 },
        "connectionId": { "type": "string", "maxLength": 80 },
        "serverType": { "type": "string", "enum": ["server", "client"] },
        "udpAddress": {
          "type": "string",
          "description": "Remote endpoint address. Required in client mode."
        },
        "udpPort": { "type": "number", "minimum": 1024, "maximum": 65535 },
        "secretKey": {
          "type": "string",
          "minLength": 32,
          "maxLength": 64,
          "pattern": "^(?:.{32}|[0-9a-fA-F]{64}|[A-Za-z0-9+/\\-_]{43}=?)$"
        },
        "protocolVersion": {
          "type": "number",
          "enum": [1, 3],
          "default": 1,
          "description": "1 (legacy) or 3 (authenticated reliable transport). A stored value of 2 is accepted as a backward-compatible alias and normalized to 3."
        },
        "stretchAsciiKey": { "type": "boolean", "default": false },
        "authenticatedHeaders": { "type": "boolean", "default": true },
        "useMsgpack": { "type": "boolean", "default": false },
        "useValueDedup": {
          "type": "boolean",
          "default": false,
          "description": "Requires protocolVersion 3 (reliable transport)."
        },
        "useCompactDeltas": {
          "type": "boolean",
          "default": false,
          "description": "Requires protocolVersion 3 and useMsgpack."
        },
        "usePathDictionary": { "type": "boolean", "default": false },
        "helloMessageSender": {
          "type": "integer",
          "minimum": 10,
          "maximum": 3600,
          "description": "Client-only. HELLO/heartbeat keepalive interval in seconds."
        },
        "heartbeatInterval": {
          "type": "number",
          "minimum": 5000,
          "maximum": 120000,
          "description": "v3 client-only. UDP NAT-keepalive heartbeat interval in ms."
        },
        "testAddress": {
          "type": "string",
          "description": "v1 client only. Reachability-probe target address."
        },
        "testPort": {
          "type": "number",
          "minimum": 1,
          "maximum": 65535,
          "description": "v1 client only."
        },
        "pingIntervalTime": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 60,
          "description": "v1 client only. Reachability-check interval in minutes."
        },
        "bonding": {
          "type": "object",
          "additionalProperties": true,
          "description": "Client-only. Not supported in server mode.",
          "properties": {
            "enabled": { "type": "boolean" },
            "mode": { "type": "string", "enum": ["main-backup"] },
            "primary": { "$ref": "#/definitions/bondingLink" },
            "backup": { "$ref": "#/definitions/bondingLink" },
            "failover": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "rttThreshold": { "type": "number", "minimum": 100, "maximum": 5000 },
                "lossThreshold": { "type": "number", "minimum": 0.01, "maximum": 0.5 },
                "healthCheckInterval": { "type": "number", "minimum": 500, "maximum": 10000 },
                "failbackDelay": { "type": "number", "minimum": 5000, "maximum": 300000 },
                "heartbeatTimeout": { "type": "number", "minimum": 1000, "maximum": 30000 }
              }
            }
          }
        },
        "congestionControl": {
          "type": "object",
          "additionalProperties": true,
          "description": "Client-only. Not supported in server mode.",
          "properties": {
            "enabled": { "type": "boolean" },
            "targetRTT": { "type": "number", "minimum": 50, "maximum": 2000 },
            "nominalDeltaTimer": { "type": "number", "minimum": 100, "maximum": 10000 },
            "minDeltaTimer": { "type": "number", "minimum": 50, "maximum": 1000 },
            "maxDeltaTimer": { "type": "number", "minimum": 1000, "maximum": 30000 }
          }
        }
      }
    },
    "bondingLink": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "address": { "type": "string" },
        "port": { "type": "number", "minimum": 1024, "maximum": 65535 },
        "interface": { "type": "string" }
      }
    }
  }
}
