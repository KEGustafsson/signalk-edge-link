# Source files (compiled output in lib/ is published instead)
src/
webpack.config.js
.babelrc
.claude/

# Configuration examples
config-examples/

# Git files
.git/
.gitignore

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build artifacts
dist/
build/
coverage/

# Source maps: do not publish webapp .map files to the npm registry even though
# package.json "files" includes public/. Combined with webpack's
# hidden-source-map devtool, this keeps maps out of the shipped package.
public/**/*.map

# Testing
test/
tests/
__tests__/
*.test.js
*.spec.js

# Execution plans
EXECUTION-PLAN-*.md

# Linting
.eslintrc*
.prettierrc*

# Environment files
.env
.env.local
.env.development
.env.test
.env.production
