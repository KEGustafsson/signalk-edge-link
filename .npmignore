# Source files (compiled output in lib/ is published instead)
src/
webpack.config.js
.babelrc
.claude/

# Configuration examples
config-examples/

# Git files
.git/
.gitignore

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build artifacts
dist/
build/
coverage/

# Source maps: the production webpack build emits no .map files (devtool:false),
# so none are published. This pattern is kept as defense-in-depth for stray maps
# from local/dev builds — note that package.json "files" overrides .npmignore for
# whitelisted trees, so not generating maps (above) is the real guarantee.
public/**/*.map

# Testing
test/
tests/
__tests__/
*.test.js
*.spec.js

# Execution plans
EXECUTION-PLAN-*.md

# Linting
.eslintrc*
.prettierrc*

# Environment files
.env
.env.local
.env.development
.env.test
.env.production
