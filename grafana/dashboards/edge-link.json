{
  "title": "Signal K Edge Link",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "RTT / Jitter",
      "targets": [
        { "expr": "edge_link_rtt_ms" },
        { "expr": "edge_link_jitter_ms" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Packet Loss / Retransmits",
      "targets": [
        { "expr": "edge_link_packet_loss" },
        { "expr": "rate(edge_link_retransmissions_total[1m])" }
      ]
    },
    {
      "type": "timeseries",
      "title": "ACK / NAK",
      "targets": [
        { "expr": "rate(edge_link_acks_sent_total[1m])" },
        { "expr": "rate(edge_link_naks_sent_total[1m])" }
      ]
    },
    {
      "type": "stat",
      "title": "Bond Switches",
      "targets": [
        { "expr": "increase(edge_link_bond_switches_total[1h])" }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
